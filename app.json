{
  "expo": {
    "name": "NAYFT Market",
    "slug": "nayft-crypto-market",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nayft",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nayft.app",
      "associatedDomains": [
        "applinks:nayft.com",
        "applinks:www.nayft.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.nayft.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 8,
      "permissions": ["POST_NOTIFICATIONS"],
      "allowBackup": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "nayft.com",
              "pathPrefix": "/share"
            },
            {
              "scheme": "https",
              "host": "www.nayft.com",
              "pathPrefix": "/share"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-localization",
      "expo-sharing",
      "@react-native-google-signin/google-signin",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "marketSnapshotUi": true,
      "eas": {
        "projectId": "a7872755-4204-424e-878d-636d76c39e88"
      }
    },
    "owner": "gyan9427"
  }
}
