{
  "expo": {
    "name": "NAYFT Market",
    "slug": "nayft-crypto-market",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "nayft.test",
      "versionCode": 2,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "minSdkVersion": 24,
      "permissions": [],
      "usesCleartextTraffic": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "nayft.test",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d3f86c59-3e74-49ce-a53a-e6963ec1226b"
      }
    },
    "owner": "nayft_user"
  }
}