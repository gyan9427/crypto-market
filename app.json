{
  "expo": {
    "name": "NAYFT Market",
    "slug": "nayft-crypto-market",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nayft",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.nayft.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 5,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "minSdkVersion": 24,
      "permissions": [],
      "allowBackup": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nayft.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-localization",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "marketSnapshotUi": true,
      "eas": {
        "projectId": "d3f86c59-3e74-49ce-a53a-e6963ec1226b"
      }
    },
    "owner": "nayft_user"
  }
}
