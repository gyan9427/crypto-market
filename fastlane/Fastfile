# frozen_string_literal: true

default_platform(:android)

def validate_play_credentials!
  UI.user_error!('PLAY_STORE_JSON_KEY_PATH or PLAY_STORE_SERVICE_ACCOUNT_JSON is required') if ENV['PLAY_STORE_JSON_KEY_PATH'].to_s.empty? && ENV['PLAY_STORE_SERVICE_ACCOUNT_JSON'].to_s.empty?
end

def setup_play_json!
  return if ENV['PLAY_STORE_JSON_KEY_PATH'] && File.exist?(ENV['PLAY_STORE_JSON_KEY_PATH'])
  return if ENV['PLAY_STORE_SERVICE_ACCOUNT_JSON'].to_s.empty?

  path = File.join(Dir.tmpdir, "play-store-#{Process.pid}.json")
  File.write(path, ENV['PLAY_STORE_SERVICE_ACCOUNT_JSON'])
  File.chmod(0o600, path)
  ENV['PLAY_STORE_JSON_KEY_PATH'] = path
end

def play_version_already_used_error?(error)
  message = error.message.to_s
  message.include?('already been used') || message.match?(/Version code \d+ has already been used/i)
end

def upload_aab_to_play!(track:, aab_path:)
  upload_to_play_store(
    track: track,
    aab: aab_path,
    release_status: 'completed',
    skip_upload_metadata: true,
    skip_upload_images: true,
    skip_upload_screenshots: true
  )
rescue StandardError => e
  raise unless play_version_already_used_error?(e)

  UI.important("Play already has this versionCode; skipping upload (#{e.message})")
  UI.success('UPLOAD_SKIPPED_ALREADY_DEPLOYED')
end

platform :android do
  before_all do
    setup_play_json!
  end

  desc 'Print max version code for a Play track'
  lane :track_version_code do |options|
    validate_play_credentials!
    track = options[:track] || UI.user_error!('track required')
    codes = google_play_track_version_codes(
      track: track,
      package_name: 'com.nayft.app'
    )
    puts(codes.max || 0)
  end

  desc 'Upload AAB to Play Internal track'
  lane :deploy_internal do |options|
    validate_play_credentials!
    aab_path = options[:aab_path] || UI.user_error!('aab_path required for deploy_internal')
    UI.message('UPLOAD_STARTED')
    upload_aab_to_play!(track: 'internal', aab_path: aab_path)
    UI.success('UPLOAD_COMPLETED')
    UI.success("Processed #{aab_path} for Play Internal track")
  end

  desc 'Upload AAB to Play Production track'
  lane :deploy_production do |options|
    validate_play_credentials!
    aab_path = options[:aab_path] || UI.user_error!('aab_path required for deploy_production')
    UI.message('UPLOAD_STARTED')
    upload_aab_to_play!(track: 'production', aab_path: aab_path)
    UI.success('UPLOAD_COMPLETED')
    UI.success("Processed #{aab_path} for Play Production track")
  end
end
