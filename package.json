{
  "name": "bolt-expo-starter",
  "main": "expo-router/entry",
  "version": "1.2.1",
  "private": true,
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "20.x",
    "npm": "10.8.2"
  },
  "scripts": {
    "postinstall": "patch-package",
    "dev": "EXPO_NO_TELEMETRY=1 expo start",
    "build:web": "expo export --platform web",
    "build:android": "npx eas-cli build -p android --profile staging --non-interactive",
    "build:android:prod": "npx eas-cli build -p android --profile production --non-interactive",
    "validate:tag": "node scripts/validate-version-tag.js",
    "ci:validate": "npm run typecheck && npm run lint && npm run test && npm run check:colors",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:colors": "npx tsx scripts/check-hardcoded-colors.ts",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/noto-sans-bengali": "^0.4.4",
    "@expo-google-fonts/noto-sans-devanagari": "^0.4.1",
    "@expo-google-fonts/noto-sans-kannada": "^0.4.3",
    "@expo-google-fonts/noto-sans-malayalam": "^0.4.2",
    "@expo-google-fonts/noto-sans-tamil": "^0.4.3",
    "@expo-google-fonts/noto-sans-telugu": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.7",
    "@lucide/lab": "^0.1.2",
    "@nayft/password-policy": "file:./packages/nayft-password-policy",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^13.1.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@shopify/react-native-skia": "2.2.12",
    "@supabase/supabase-js": "^2.58.0",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "date-fns": "^4.1.0",
    "expo": "~54.0.35",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.9",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.9",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "i18next": "^26.0.4",
    "lucide-react-native": "^0.544.0",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.2",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-inappbrowser-reborn": "^3.7.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.18",
    "zustand": "^5.0.9"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "patch-package": "^8.0.1",
    "tsx": "^4.19.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.8"
  }
}
