# Copy to .env. EXPO_PUBLIC_* is inlined when Metro bundles (dev + EAS).
#
# Production API (typical for installed APK / real device against live backend):
# EXPO_PUBLIC_API_BASE_URL=https://api.nayft.com/api
#
# Local backend — physical device: your LAN IP; Android emulator: 10.0.2.2
EXPO_PUBLIC_API_BASE_URL=http://YOUR_MACHINE_IP:4001/api
