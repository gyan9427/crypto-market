# Copy to .env. EXPO_PUBLIC_* is inlined when Metro bundles (dev + EAS).
#
# Default: production (real device / Expo Go). Do not use localhost or 0.0.0.0 on a phone.
EXPO_PUBLIC_API_BASE_URL=https://api.nayft.com/api
#
# Local backend — set to localhost; the app rewrites per platform (emulator → 10.0.2.2, device → Metro LAN IP):
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4001/api
# Or pin your LAN IP: http://YOUR_LAN_IP:4001/api  |  Never use http://0.0.0.0:4001/api

# --- CI/CD (local Fastlane / eas only — .env is gitignored) ---
# GitHub Actions: add EXPO_TOKEN + PLAY_STORE_SERVICE_ACCOUNT_JSON in Settings → Environments
# See secrets/README.md and docs/GITHUB_SECRETS_SETUP.md
# EXPO_TOKEN=
# EXPO_PUBLIC_STORE_URL=https://play.google.com/store
# EXPO_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/nayft/idXXXXXXXX
# EXPO_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.nayft.app
# EXPO_PUBLIC_NAYFT_DOWNLOAD_URL=https://nayft.com
# Backend NAYFT_SHARE_BASE_URL must match (https://nayft.com) for shareMeta.shareUrl
#
# Universal Links / App Links (Phase 2 — requires new native build via EAS):
# iOS: associatedDomains in app.json → applinks:nayft.com, applinks:www.nayft.com
# Android: intentFilters with autoVerify in app.json
# Marketing site must serve /.well-known/apple-app-site-association and assetlinks.json
# with APPLE_TEAM_ID and ANDROID_APP_LINK_SHA256 set on the marketing deploy.
