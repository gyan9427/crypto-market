# Copy to .env. EXPO_PUBLIC_* is inlined when Metro bundles (dev + EAS).
#
# Default: production (real device / Expo Go). Do not use localhost on a phone.
EXPO_PUBLIC_API_BASE_URL=https://api.nayft.com/api
#
# Local backend — simulator: http://localhost:4001/api
# Physical device: http://YOUR_LAN_IP:4001/api  |  Android emulator: http://10.0.2.2:4001/api
